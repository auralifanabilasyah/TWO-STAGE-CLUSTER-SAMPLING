
library(readxl)
library(dplyr)
library(psych)

# Import Data

data <- read_excel("C:/Users/ASUS/Downloads/Formulir tanpa judul (Jawaban).xlsx")

# Melihat Struktur Data

str(data)
names(data)

# Mengambil Item Kuesioner

item <- data[,6:17]

# Uji Validitas

hasil_validitas <- data.frame()

for(i in 1:ncol(item)){
  
  skor_total <- rowSums(item[,-i])
  
  uji <- cor.test(
    item[[i]],
    skor_total
  )
  
  hasil_validitas <- rbind(
    hasil_validitas,
    data.frame(
      Item = names(item)[i],
      r_hitung = round(as.numeric(uji$estimate),4),
      p_value = round(uji$p.value,4)
    )
  )
  
}

hasil_validitas

hasil_validitas$Keterangan <- ifelse(
  hasil_validitas$p_value < 0.05,
  "Valid",
  "Tidak Valid"
)

hasil_validitas

# Uji Reliabilitas

hasil_alpha <- alpha(item)

hasil_alpha

hasil_alpha$total

# Cleaning Data

colSums(is.na(data))

boxplot(
  rowMeans(item),
  main = "Boxplot Skor Kepuasan"
)

# Membentuk Skor Kepuasan

data$Skor_Kepuasan <- rowMeans(item)

summary(data$Skor_Kepuasan)

# Kategori Tingkat Kepuasan

data$Tingkat <- cut(
  data$Skor_Kepuasan,
  breaks = c(
    1,
    1.75,
    2.50,
    3.25,
    4.00
  ),
  labels = c(
    "Sangat Tidak Puas",
    "Tidak Puas",
    "Puas",
    "Sangat Puas"
  ),
  include.lowest = TRUE
)

table(data$Tingkat)

prop.table(
  table(data$Tingkat)
)*100

# Ukuran Populasi

N <- nrow(data)

N

# Simple Random Sampling

set.seed(123)

n <- 20

srs <- sample_n(
  data,
  n
)

srs

# Response Rate SRS

response_rate_srs <- nrow(srs)/n

response_rate_srs

# Peluang Pemilihan SRS

prob_srs <- n/N

prob_srs

# Bobot Dasar SRS

bobot_srs <- 1/prob_srs

bobot_srs

srs$Bobot <- bobot_srs

# Estimasi Mean SRS

mean_srs <- weighted.mean(
  srs$Skor_Kepuasan,
  srs$Bobot
)

mean_srs

# Standard Error SRS

SE_srs <- sqrt(
  (1 - n/N) *
    var(srs$Skor_Kepuasan)/n
)

SE_srs

# Interval Kepercayaan 95%

lower_srs <- mean_srs -
  1.96*SE_srs

upper_srs <- mean_srs +
  1.96*SE_srs

lower_srs

upper_srs

# Relative Standard Error

RSE_srs <- (
  SE_srs/mean_srs
)*100

RSE_srs

# Kategori Tingkat Populasi SRS

kategori_srs <- cut(
  mean_srs,
  breaks = c(
    1,
    1.75,
    2.50,
    3.25,
    4.00
  ),
  labels = c(
    "Sangat Tidak Puas",
    "Tidak Puas",
    "Puas",
    "Sangat Puas"
  )
)

kategori_srs

# Cluster Sampling 2 Tahap
# Tahap 1 : Memilih Kelas

unique(data$KELAS)

set.seed(123)

kelas_terpilih <- sample(
  unique(data$KELAS),
  2
)

kelas_terpilih

# Tahap 2 : Memilih Mahasiswa

cluster_sample <- data %>%
  filter(KELAS %in% kelas_terpilih) %>%
  group_by(KELAS) %>%
  sample_n(5)

cluster_sample

# Response Rate Cluster

response_rate_cluster <- nrow(cluster_sample)/10

response_rate_cluster

# Peluang Tahap Pertama

M <- length(
  unique(data$KELAS)
)

m <- length(
  kelas_terpilih
)

P1 <- m/M

P1

# Peluang Tahap Kedua

cluster_sample <- cluster_sample %>%
  mutate(
    ukuran_cluster =
      nrow(
        data %>%
          filter(
            KELAS == first(KELAS)
          )
      )
  )

P2 <- 5/
  mean(cluster_sample$ukuran_cluster)

P2

# Peluang Total

P <- P1*P2

P

# Bobot Dasar Cluster

Bobot_Cluster <- 1/P

Bobot_Cluster

cluster_sample$Bobot <- Bobot_Cluster

# Estimasi Mean Cluster

mean_cluster <- weighted.mean(
  cluster_sample$Skor_Kepuasan,
  cluster_sample$Bobot
)

mean_cluster

# Standard Error Cluster

SE_cluster <- sd(
  cluster_sample$Skor_Kepuasan
)/sqrt(
  nrow(cluster_sample)
)

SE_cluster

# Interval Kepercayaan 95%

lower_cluster <- mean_cluster -
  1.96*SE_cluster

upper_cluster <- mean_cluster +
  1.96*SE_cluster

lower_cluster

upper_cluster

# Relative Standard Error

RSE_cluster <- (
  SE_cluster/mean_cluster
)*100

RSE_cluster

# Kategori Tingkat Populasi Cluster

kategori_cluster <- cut(
  mean_cluster,
  breaks = c(
    1,
    1.75,
    2.50,
    3.25,
    4.00
  ),
  labels = c(
    "Sangat Tidak Puas",
    "Tidak Puas",
    "Puas",
    "Sangat Puas"
  )
)

kategori_cluster

# Design Effect

Deff <- (
  SE_cluster^2
)/(
  SE_srs^2
)

Deff

# Tabel Perbandingan

hasil <- data.frame(
  Metode = c(
    "SRS",
    "Cluster 2 Tahap"
  ),
  Estimasi = c(
    mean_srs,
    mean_cluster
  ),
  Tingkat = c(
    as.character(kategori_srs),
    as.character(kategori_cluster)
  ),
  SE = c(
    SE_srs,
    SE_cluster
  ),
  RSE = c(
    RSE_srs,
    RSE_cluster
  ),
  LowerCI = c(
    lower_srs,
    lower_cluster
  ),
  UpperCI = c(
    upper_srs,
    upper_cluster
  )
)

hasil

if(Deff < 1){
  print("Cluster lebih efisien")
}else if(Deff == 1){
  print("SRS dan Cluster sama efisien")
}else{
  print("SRS lebih efisien")
}
